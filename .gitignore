# =============================================================================
# SiWorkGroup .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Environment & Secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# Python (Backend)
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyd
*.pyo

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
*.egg
*.egg-info/
dist/
build/
.eggs/
sdist/
wheels/

# Testing & coverage
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
nosetests.xml
pytest.xml

# Type checking & linting caches
.mypy_cache/
.ruff_cache/
.dmypy.json
dmypy.json

# Jupyter Notebooks
.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# Node.js / Frontend
# -----------------------------------------------------------------------------
node_modules/
jspm_packages/

# Next.js
.next/
out/

# Build output
dist/

# npm / yarn
.npm
.yarn-integrity
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# TypeScript
*.tsbuildinfo

# Caches
.eslintcache
.stylelintcache
.parcel-cache/

# Vite timestamps
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Test coverage
coverage/
*.lcov
.nyc_output/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# -----------------------------------------------------------------------------
# OS & IDE
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
desktop.ini

# JetBrains IDEs
.idea/

# VS Code (keep workspace settings if desired)
# .vscode/

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
# Local override files (not for VCS)
docker-compose.override.yml

# -----------------------------------------------------------------------------
# Intermediate / Debug Output Files
# (generated by setup scripts and debugging sessions)
# -----------------------------------------------------------------------------
# Root-level debug output
/*.txt
/*.json

# Backend debug output
backend/*.txt
backend/*.json

# Frontend debug output
frontend/*.txt

# -----------------------------------------------------------------------------
# Alembic
# -----------------------------------------------------------------------------
# Keep all migration files; ignore only local temp artifacts
alembic.ini.bak

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
*.tgz
*.zip
*.tar.gz
*.bak
*.swp
*.swo
*~
.temp/
.cache/
tmp/
temp/