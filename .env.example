# =============================================================================
# SiWorkGroup - Environment Variables Example
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=SiWorkGroup
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://siuser:sipass@localhost:5432/siworkgroup
DATABASE_URL_SYNC=postgresql://siuser:sipass@localhost:5432/siworkgroup

POSTGRES_USER=siuser
POSTGRES_PASSWORD=sipass
POSTGRES_DB=siworkgroup
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# -----------------------------------------------------------------------------
# JWT / Auth
# -----------------------------------------------------------------------------
SECRET_KEY=your-super-secret-key-change-in-production-must-be-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30
ALGORITHM=HS256

# -----------------------------------------------------------------------------
# LLM Provider - LiteLLM (OpenAI-compatible proxy)
#
# This project uses LiteLLM as the unified LLM gateway.
# LiteLLM exposes an OpenAI-compatible REST API, so we reuse the OPENAI_*
# variable names — the OpenAI Python SDK will automatically route all requests
# through LiteLLM instead of calling OpenAI directly.
#
# Quick start (LiteLLM proxy):
#   pip install litellm
#   litellm --model ollama/llama3 --port 4000
#   # or with a config file:
#   litellm --config litellm_config.yaml --port 4000
#
# See: https://docs.litellm.ai/docs/proxy/quick_start
# -----------------------------------------------------------------------------

# URL of your LiteLLM proxy (default port: 4000)
OPENAI_BASE_URL=https://copilot.huya.info/api/litellm/

# LiteLLM master key or virtual key
# Set with --master-key when starting the proxy, or leave blank if auth is disabled
OPENAI_API_KEY=sk-w3qEglCH8x6_wBPoRQQldQ

# Default model — must match a model name / alias configured in LiteLLM
# Examples: gpt-4o, gpt-3.5-turbo, claude-3-5-sonnet-20241022, ollama/llama3
DEFAULT_MODEL=anthropic/claude-sonnet-4-6

# -----------------------------------------------------------------------------
# Docker / Sandbox
# -----------------------------------------------------------------------------
DOCKER_HOST=unix:///var/run/docker.sock
SANDBOX_IMAGE=siworkgroup/claw-sandbox:latest
SANDBOX_NETWORK=siworkgroup_sandbox
SANDBOX_CPU_DEFAULT=1.0
SANDBOX_MEMORY_DEFAULT=2g
SANDBOX_DISK_DEFAULT=10g

# -----------------------------------------------------------------------------
# Celery
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# Frontend (Next.js)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000