# =============================================================================
# SiWorkGroup - Environment Variables Example
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=SiWorkGroup
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://siuser:sipass@localhost:5432/siworkgroup
DATABASE_URL_SYNC=postgresql://siuser:sipass@localhost:5432/siworkgroup

POSTGRES_USER=siuser
POSTGRES_PASSWORD=sipass
POSTGRES_DB=siworkgroup
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# -----------------------------------------------------------------------------
# JWT / Auth
# -----------------------------------------------------------------------------
SECRET_KEY=your-super-secret-key-change-in-production-must-be-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30
ALGORITHM=HS256

# -----------------------------------------------------------------------------
# OpenAI / Model Service
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
DEFAULT_MODEL=gpt-4o

# -----------------------------------------------------------------------------
# Docker / Sandbox
# -----------------------------------------------------------------------------
DOCKER_HOST=unix:///var/run/docker.sock
SANDBOX_IMAGE=siworkgroup/claw-sandbox:latest
SANDBOX_NETWORK=siworkgroup_sandbox
SANDBOX_CPU_DEFAULT=1.0
SANDBOX_MEMORY_DEFAULT=2g
SANDBOX_DISK_DEFAULT=10g

# -----------------------------------------------------------------------------
# Celery
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# Frontend (Next.js)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000